<?xml version="1.0"?>

<configurator>
  <domain name="CHIP"/>
  <bitmap name="AlarmBitmap" type="bitmap32">
     <cluster code="0x15E7FC02" />
    <field name="FanFailure" mask="0x00000001"/>
    <field name="FreezerTemperatureSensorFailure" mask="0x00000002"/>
    <field name="FridgeTemperatureSensorFailure" mask="0x00000004"/>
    <field name="DefrostTemperatureSensorFailure" mask="0x00000008"/>
  </bitmap>
  <cluster>
    <name>Fresh Refrigerator Errors Alarm</name>
    <domain>FRESH</domain>
    <description>Attributes and commands for configuring the Fresh Refrigerator Errors alarm.</description>
    <code>0x15E7FC02</code>
    <define>FRESH_REFRIGERATOR_ERRORS_CLUSTER</define>
    <client tick="false" init="false">true</client>
    <server tick="false" init="false">true</server>
    <globalAttribute code="0xFFFD" side="either" value="1"/>
    <features>
      <feature bit="0" code="RESET" name="Reset" summary="Supports the ability to reset alarms">
        <optionalConform/>
      </feature>
    </features>
    
    <attribute side="server" code="0x0000" name="Mask" define="MASK" type="AlarmBitmap" default="0" min="0x00000000" max="0x0000000F">Mask</attribute>
    <attribute side="server" code="0x0001" name="Latch" define="LATCH" type="AlarmBitmap" default="0" optional="true" min="0x00000000" max="0x0000000F">
      <description>Latch</description>
      <mandatoryConform>
        <feature name="RESET"/>
      </mandatoryConform>
    </attribute>
   <attribute side="server" code="0x0002" name="State" define="STATE" type="AlarmBitmap" default="0" min="0x00000000" max="0x0000000F">State</attribute>
   <attribute side="server" code="0x0003" name="Supported" define="SUPPORTED" type="AlarmBitmap" default="0" min="0x00000000" max="0x0000000F">Supported</attribute>

   <command source="client" code="0x00" name="Reset" optional="true">
      <description>This command resets active and latched alarms (if possible).</description>
      <arg id="0" name="Alarms" type="AlarmBitmap" default="0x00000000" min="0x00000000" max="0x0000000F"/>
      <mandatoryConform>
        <feature name="RESET"/>
      </mandatoryConform>
    </command>

    <event side="server" code="0x00" priority="info" name="Notify">
      <description>This event SHALL be generated when one or more alarms change state, and SHALL have these fields: </description>
      <field id="0" name="Active" type="AlarmBitmap" default="0x00000000" min="0x00000000" max="0x0000000F"/>
      <field id="1" name="Inactive" type="AlarmBitmap" default="0x00000000" min="0x00000000" max="0x0000000F"/>
      <field id="2" name="State" type="AlarmBitmap" default="0x00000000" min="0x00000000" max="0x0000000F"/>
      <field id="3" name="Mask" type="AlarmBitmap" default="0x00000000" min="0x00000000" max="0x0000000F"/>
    </event>
  </cluster>
</configurator>
